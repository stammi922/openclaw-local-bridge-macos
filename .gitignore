# Backups created by the installer at runtime — never committed
*.bak
*.bak.*
bridge-backups/

# Local env files
.env
.env.*

# Local logs
*.log

# Defensive: never commit user accounts state or rotator config, even though
# they normally live outside the repo under ~/.openclaw/bridge/.
bridge/accounts/
/rotator.config.json
/accounts.json

# macOS cruft
.DS_Store

# Editor / IDE
.idea/
.vscode/
*.swp
