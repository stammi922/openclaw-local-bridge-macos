# Backups created by the installer at runtime — never committed
*.bak
*.bak.*
bridge-backups/

# Local env files
.env
.env.*

# Local logs
*.log

# macOS cruft
.DS_Store

# Editor / IDE
.idea/
.vscode/
*.swp

# Node / TypeScript
node_modules/
coverage/
.vitest-temp/
dist/
!proxy/dist/

# openclaw CLI creates this in cwd when the gateway endpoint isn't
# reachable (ENOENT mkdir '/agents' → fallback to relative). The
# directory contains auth-profiles.json with credentials — never commit.
agents/

# Superpowers / agent working notes (plans, specs, brainstorms, research).
# Public repo: keep these out — they routinely contain infra/business detail
# (device ids, cron names, hostnames). Enforced by scripts/git-hooks/pre-commit.
docs/superpowers/
